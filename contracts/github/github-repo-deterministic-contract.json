{
  "contract_format_version": 1,
  "kind": "github_repository_contract",
  "name": "ceratops_github_repo_deterministic_contract",
  "captured_on": "2026-05-02",
  "source_files": [
    {
      "path": "$AI_AGENT_SKILLS_ROOT/contracts/source-docs.json",
      "lines": "source-doc registry"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/templates/sections/gh-repo-health-contract.md",
      "lines": "contract owner"
    }
  ],
  "parameters": {
    "owner": {
      "type": "string",
      "required": true
    },
    "repo": {
      "type": "string",
      "required": true
    },
    "default_branch": {
      "type": "string",
      "required": false,
      "default_from": "repo.default_branch"
    },
    "expected_codeowners_owners": {
      "type": "array",
      "required": false,
      "default": []
    },
    "expected_required_checks": {
      "type": "array",
      "required": false,
      "default": []
    },
    "artifact_publishers": {
      "type": "array",
      "required": false,
      "default": []
    },
    "local_repo_path": {
      "type": "string",
      "required": false
    },
    "expected_maintainer_bypass_actors": {
      "type": "array",
      "required": false,
      "default": []
    },
    "approved_drift_profile": {
      "type": "string",
      "required": false,
      "default": "default"
    }
  },
  "required_scopes": [
    "repo",
    "workflow"
  ],
  "optional_scopes_for_full_screen_parity": [
    {
      "scope": "admin:org",
      "enables": [
        "security.code_security_configuration_attached"
      ],
      "reason": "Needed only when the checker must verify org-level code security configuration attachment/default posture for repositories owned by an organization."
    }
  ],
  "source_docs_ref": "../source-docs.json",
  "source_doc_scopes": [
    "repo"
  ],
  "approved_drift": {
    "exclusions": [],
    "allowances": [
      {
        "id": "forks_may_defer_enforcement_to_upstream",
        "when": "repo.fork == true",
        "check_ids": [
          "process.default_branch_enforcement_present",
          "process.branch_protection_or_ruleset_posture",
          "security.dependency_review_availability"
        ],
        "reason": "Forks can have unavailable or upstream-owned enforcement surfaces; classify rather than mutate."
      },
      {
        "id": "archived_repos_report_only",
        "when": "repo.archived == true",
        "check_ids": [
          "*"
        ],
        "reason": "Archived repositories are immutable health inventory, not repair targets."
      }
    ]
  },
  "remediation_policy": {
    "default": "report_only",
    "apply_flag": "--apply",
    "auto_apply_check_ids": [
      "repo.merge_settings",
      "repo.topics_required",
      "security.dependabot_security_updates_enabled",
      "security.vulnerability_alerts_enabled",
      "security.private_vulnerability_reporting_public",
      "content.dependencies_label_when_dependabot_uses_it"
    ],
    "manual_check_ids": [
      "repo.identity_public_contract",
      "process.default_branch_enforcement_present",
      "process.branch_protection_or_ruleset_posture",
      "security.open_dependabot_pr_queue",
      "stale_state.*"
    ],
    "destructive_or_irreversible": "always_report_only"
  },
  "type_system": {
    "dimensions": [
      {
        "id": "visibility",
        "values": [
          "public",
          "private",
          "internal"
        ],
        "detector": "repo.visibility"
      },
      {
        "id": "origin",
        "values": [
          "source",
          "fork",
          "template"
        ],
        "detectors": [
          {
            "value": "fork",
            "when": "repo.fork == true"
          },
          {
            "value": "template",
            "when": "repo.is_template == true"
          },
          {
            "value": "source",
            "when": "repo.fork == false && repo.is_template == false"
          }
        ]
      },
      {
        "id": "lifecycle",
        "values": [
          "active",
          "archived",
          "disabled"
        ],
        "detectors": [
          {
            "value": "archived",
            "when": "repo.archived == true"
          },
          {
            "value": "disabled",
            "when": "repo.disabled == true"
          },
          {
            "value": "active",
            "when": "repo.archived == false && repo.disabled == false"
          }
        ]
      },
      {
        "id": "project_surface",
        "values": [
          "software",
          "documentation_only",
          "iac",
          "automation",
          "website",
          "library_or_sdk",
          "service_or_app",
          "unknown"
        ],
        "detectors": [
          {
            "value": "software",
            "when_any_path_matches": [
              "src/**",
              "app/**",
              "lib/**",
              "pyproject.toml",
              "package.json",
              "go.mod",
              "Cargo.toml",
              "pom.xml",
              "*.csproj",
              "*.sln"
            ]
          },
          {
            "value": "library_or_sdk",
            "when_any_path_matches": [
              "pyproject.toml",
              "package.json",
              "go.mod",
              "Cargo.toml",
              "pom.xml",
              "*.csproj",
              "*.nuspec",
              "*.gemspec"
            ]
          },
          {
            "value": "iac",
            "when_any_path_matches": [
              "*.tf",
              "Chart.yaml",
              "charts/**/Chart.yaml",
              "k8s/**",
              "kubernetes/**",
              "manifests/**"
            ]
          },
          {
            "value": "automation",
            "when_any_path_matches": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml",
              "action.yml",
              "action.yaml",
              "scripts/**"
            ]
          },
          {
            "value": "website",
            "when_any_path_matches": [
              "docs/**",
              "public/**",
              "site/**",
              "mkdocs.yml",
              "docusaurus.config.*",
              "next.config.*"
            ],
            "or_when": "repo.has_pages == true"
          },
          {
            "value": "service_or_app",
            "when_any_path_matches": [
              "Dockerfile",
              "**/Dockerfile",
              "Procfile",
              "docker-compose.yml",
              "compose.yml",
              "compose.yaml",
              "app/**"
            ]
          },
          {
            "value": "documentation_only",
            "when": "tree_has_readme_or_docs == true && no_software_artifact_iac_or_workflow_signals == true"
          }
        ]
      },
      {
        "id": "workflow_surface",
        "values": [
          "no_workflows",
          "has_workflows",
          "has_release_workflow",
          "has_attestation_workflow"
        ],
        "detectors": [
          {
            "value": "has_workflows",
            "when_any_path_matches": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml"
            ]
          },
          {
            "value": "has_release_workflow",
            "when_workflow_contains_any": [
              "gh release",
              "softprops/action-gh-release",
              "pypa/gh-action-pypi-publish",
              "npm publish",
              "docker/build-push-action",
              "docker/login-action",
              "crates.io",
              "rubygems",
              "nuget push",
              "mvn deploy"
            ]
          },
          {
            "value": "has_attestation_workflow",
            "when_workflow_contains_any": [
              "actions/attest",
              "attestations: write",
              "artifact-metadata: write"
            ]
          }
        ]
      },
      {
        "id": "artifact_surface",
        "values": [
          "no_artifact",
          "docker_oci_image",
          "pypi_python_package",
          "npm_package",
          "maven_package",
          "nuget_package",
          "crates_package",
          "rubygems_package",
          "powershell_gallery_module",
          "github_release_binary",
          "github_pages_site",
          "github_packages_other"
        ],
        "detectors": [
          {
            "value": "docker_oci_image",
            "confidence": "high",
            "when_any_path_matches": [
              "Dockerfile",
              "docker/Dockerfile",
              "**/Dockerfile"
            ]
          },
          {
            "value": "docker_oci_image",
            "confidence": "high",
            "when_any_topic_matches": [
              "docker",
              "oci",
              "container",
              "ghcr"
            ]
          },
          {
            "value": "pypi_python_package",
            "confidence": "high",
            "when_any_path_matches": [
              "pyproject.toml",
              "setup.cfg",
              "setup.py"
            ],
            "and_when_file_contains_any": {
              "pyproject.toml": [
                "[project]",
                "[tool.poetry]",
                "[build-system]"
              ]
            }
          },
          {
            "value": "npm_package",
            "confidence": "high",
            "when_any_path_matches": [
              "package.json"
            ]
          },
          {
            "value": "maven_package",
            "confidence": "high",
            "when_any_path_matches": [
              "pom.xml"
            ]
          },
          {
            "value": "nuget_package",
            "confidence": "high",
            "when_any_path_matches": [
              "*.csproj",
              "*.nuspec"
            ]
          },
          {
            "value": "crates_package",
            "confidence": "high",
            "when_any_path_matches": [
              "Cargo.toml"
            ]
          },
          {
            "value": "rubygems_package",
            "confidence": "high",
            "when_any_path_matches": [
              "*.gemspec",
              "Gemfile"
            ]
          },
          {
            "value": "powershell_gallery_module",
            "confidence": "high",
            "when_any_path_matches": [
              "*.psd1"
            ]
          },
          {
            "value": "github_release_binary",
            "confidence": "medium",
            "when_release_assets_count_gt": 0
          },
          {
            "value": "github_pages_site",
            "confidence": "high",
            "when": "repo.has_pages == true"
          }
        ]
      },
      {
        "id": "language_or_iac",
        "values": [
          "python",
          "javascript_or_typescript",
          "go",
          "rust",
          "dotnet",
          "java",
          "terraform",
          "kubernetes",
          "helm",
          "github_actions"
        ],
        "detectors": [
          {
            "value": "python",
            "when_any_path_matches": [
              "pyproject.toml",
              "requirements*.txt",
              "*.py"
            ]
          },
          {
            "value": "javascript_or_typescript",
            "when_any_path_matches": [
              "package.json",
              "*.js",
              "*.ts",
              "*.tsx"
            ]
          },
          {
            "value": "go",
            "when_any_path_matches": [
              "go.mod"
            ]
          },
          {
            "value": "rust",
            "when_any_path_matches": [
              "Cargo.toml"
            ]
          },
          {
            "value": "dotnet",
            "when_any_path_matches": [
              "*.csproj",
              "*.sln"
            ]
          },
          {
            "value": "java",
            "when_any_path_matches": [
              "pom.xml",
              "build.gradle",
              "build.gradle.kts"
            ]
          },
          {
            "value": "terraform",
            "when_any_path_matches": [
              "*.tf"
            ]
          },
          {
            "value": "kubernetes",
            "when_any_file_contains_any": [
              "apiVersion:",
              "kind: Deployment",
              "kind: Service",
              "kind: Ingress"
            ]
          },
          {
            "value": "helm",
            "when_any_path_matches": [
              "Chart.yaml",
              "charts/**/Chart.yaml"
            ]
          },
          {
            "value": "github_actions",
            "when_any_path_matches": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml"
            ]
          }
        ]
      }
    ],
    "type_resolution_rules": [
      {
        "id": "topics_are_secondary",
        "rule": "Repository topics can add types, but path, manifest, workflow, release, and API signals are stronger than topics alone."
      },
      {
        "id": "multi_type_repos_are_allowed",
        "rule": "A repo may have multiple artifact, language, and IaC types; all matching conditional checks apply unless approved drift excludes them."
      },
      {
        "id": "archived_repos_are_inventory",
        "rule": "Archived repos are classified, but mutating repair checks become report-only."
      }
    ]
  },
  "fetch_bundles": [
    {
      "id": "repo_identity_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}",
          "covers_checks": [
            "repo.identity_public_contract",
            "repo.unused_feature_flags",
            "repo.merge_settings",
            "security.security_and_analysis_status",
            "type.visibility_origin_lifecycle"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/topics",
          "covers_checks": [
            "repo.topics_required",
            "type.topic_signals"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/community/profile",
          "covers_checks": [
            "content.community_profile_public"
          ]
        }
      ]
    },
    {
      "id": "local_repo_scan_bundle",
      "sources": [
        "${local_repo_path}"
      ],
      "covers_checks": [
        "actions.permissions_policy",
        "content.dependencies_label_when_dependabot_uses_it"
      ],
      "applies_when": "local_repo_path is provided"
    },
    {
      "id": "process_enforcement_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/rulesets",
          "covers_checks": [
            "process.default_branch_enforcement_present",
            "process.branch_protection_or_ruleset_posture",
            "process.maintainer_bypass_ruleset"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/branches/${default_branch}/protection",
          "covers_checks": [
            "process.default_branch_name_and_protection_indicator",
            "process.default_branch_enforcement_present",
            "process.branch_protection_or_ruleset_posture"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/collaborators/${actor}/permission",
          "covers_checks": [
            "process.maintainer_bypass_ruleset"
          ]
        }
      ]
    },
    {
      "id": "actions_policy_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions",
          "covers_checks": [
            "actions.permissions_policy"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions/workflow",
          "covers_checks": [
            "actions.workflow_token_permissions"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions/fork-pr-workflows-private-repos",
          "covers_checks": [
            "actions.private_fork_pr_workflows"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/runs?branch=${default_branch}&per_page=20",
          "covers_checks": [
            "actions.latest_default_branch_runs"
          ]
        }
      ]
    },
    {
      "id": "security_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/vulnerability-alerts",
          "covers_checks": [
            "security.vulnerability_alerts_enabled"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/automated-security-fixes",
          "covers_checks": [
            "security.dependabot_security_updates_enabled"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/dependabot/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "security.open_dependabot_alert_queue"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/code-scanning/default-setup",
          "covers_checks": [
            "security.code_scanning_default_setup_or_custom"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/code-scanning/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "security.open_code_scanning_alert_queue",
            "security.code_scanning_default_setup_or_custom"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/secret-scanning/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "security.open_secret_scanning_alert_queue"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/private-vulnerability-reporting",
          "covers_checks": [
            "security.private_vulnerability_reporting_public"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/dependency-graph/compare/${default_branch}...${default_branch}",
          "covers_checks": [
            "security.dependency_review_availability"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/code-security-configuration",
          "covers_checks": [
            "security.code_security_configuration_attached"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/labels/dependencies",
          "covers_checks": [
            "content.dependencies_label_when_dependabot_uses_it"
          ]
        }
      ]
    },
    {
      "id": "release_and_stale_state_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/releases?per_page=100",
          "covers_checks": [
            "stale_state.releases"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/tags?per_page=100",
          "covers_checks": [
            "stale_state.tags"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/branches?per_page=100",
          "covers_checks": [
            "stale_state.branches"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/pulls?state=open&per_page=100",
          "covers_checks": [
            "stale_state.pull_requests"
          ]
        }
      ]
    }
  ],
  "checks": [
    {
      "id": "type.visibility_origin_lifecycle",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8",
        "gh-repo-health-contract.md:3-8",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "classification",
      "comparison": "derive_types",
      "applies_when": "always",
      "expected": {
        "must_classify_dimensions": [
          "visibility",
          "origin",
          "lifecycle"
        ]
      }
    },
    {
      "id": "type.topic_signals",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards"
      ],
      "kind": "classification",
      "comparison": "derive_types_from_topics",
      "applies_when": "always",
      "expected": {
        "topics_are_secondary": true
      }
    },
    {
      "id": "repo.identity_public_contract",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}",
      "comparison": "selected_fields_policy",
      "applies_when": "repo.archived == false",
      "expected": {
        "owner.login": "${owner}",
        "name": "${repo}",
        "default_branch": "${default_branch}",
        "visibility": "one_of:public,private,internal",
        "description": {
          "required_when": "repo.visibility == public",
          "non_empty": true,
          "allow_approved_empty": true
        },
        "homepage": {
          "required_when": "repo.has_pages == true || repo.topics includes website",
          "allow_null": true
        }
      }
    },
    {
      "id": "repo.topics_required",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/topics",
      "comparison": "policy",
      "applies_when": "repo.visibility == public && repo.archived == false",
      "expected": {
        "names.min_count": 1,
        "names.must_reflect_detected_artifact_types": true
      }
    },
    {
      "id": "repo.unused_feature_flags",
      "source_lines": [
        "ceratops-gh-repo-create-and-publish/SKILL.md:151",
        "source-docs.json:repo-and-artifact-standards"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}",
      "comparison": "unused_feature_policy",
      "applies_when": "repo.archived == false",
      "expected": {
        "has_wiki": "false_unless_docs_or_support_route_uses_wiki",
        "has_projects": "false_unless_project_boards_are_used",
        "has_discussions": "false_unless_support_or_community_route_uses_discussions",
        "has_pages": "true_only_when_pages_site_artifact_or_homepage_expected"
      }
    },
    {
      "id": "repo.merge_settings",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}",
      "comparison": "selected_fields_equal",
      "applies_when": "repo.archived == false && repo.fork == false",
      "expected": {
        "allow_auto_merge": true,
        "delete_branch_on_merge": true,
        "allow_update_branch": true
      },
      "profile_defaults": {
        "merge_methods": {
          "allow_squash_merge": true,
          "allow_merge_commit": "allowed_if_approved",
          "allow_rebase_merge": "allowed_if_approved"
        }
      }
    },
    {
      "id": "process.default_branch_name_and_protection_indicator",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/branches/${default_branch}",
      "comparison": "selected_fields_policy",
      "applies_when": "repo.archived == false && repo.fork == false",
      "expected": {
        "name": "${default_branch}",
        "protected": {
          "must_be_true_unless_ruleset_enforces_default_branch": true
        }
      }
    },
    {
      "id": "process.default_branch_enforcement_present",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api_composite",
      "endpoints": [
        "/repos/${owner}/${repo}/rulesets",
        "/repos/${owner}/${repo}/branches/${default_branch}/protection"
      ],
      "comparison": "any_enforcement_layer",
      "applies_when": "repo.archived == false && repo.fork == false",
      "expected": {
