{
  "contract_format_version": 1,
  "kind": "artifact_registry_contract",
  "name": "ceratops_artifact_deterministic_contract",
  "captured_on": "2026-05-02",
  "source_files": [
    {
      "path": "$AI_AGENT_SKILLS_ROOT/templates/sections/gh-artifact-contract.md",
      "lines": "1-6"
    }
  ],
  "parameters": {
    "owner": {
      "type": "string",
      "required": true
    },
    "repo": {
      "type": "string",
      "required": true
    },
    "owner_type": {
      "type": "string",
      "required": false,
      "allowed_values": [
        "org",
        "user",
        "autodetect"
      ],
      "default": "autodetect"
    },
    "default_branch": {
      "type": "string",
      "required": false,
      "default_from": "repo.default_branch"
    },
    "local_repo_path": {
      "type": "string",
      "required": false
    },
    "artifact_contracts": {
      "type": "array",
      "required": false,
      "description": "Optional per-artifact expected identity records. If omitted, the checker derives candidates and reports missing contract data.",
      "item_shape": {
        "artifact_id": "stable local contract id",
        "artifact_type": "one artifact_type_system.artifact_types value",
        "registry": "registry host or github_release/pages",
        "package_or_image_name": "external artifact name",
        "version_source": "manifest, git tag, release tag, package metadata, or explicit approved source",
        "release_policy": "manual, tag-driven, workflow-driven, no-artifact, or approved custom value",
        "tag_style": "semver, v-prefix-semver, calendar, sha, digest, or approved custom value",
        "changelog_source": "CHANGELOG.md, GitHub release notes, package metadata, or approved custom value",
        "post_publish_consumer_check": "command or endpoint used to verify consumers can fetch and use the published artifact"
      }
    },
    "current_change_affects_artifact": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "final_answer_makes_artifact_claim": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "merged_change_requires_release": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "audit_only": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "approved_drift_profile": {
      "type": "string",
      "required": false,
      "default": "default"
    }
  },
  "required_scopes": [
    "repo",
    "workflow"
  ],
  "optional_scopes_for_full_screen_parity": [
    {
      "scope": "read:packages",
      "enables": [
        "github_packages.live_package_metadata"
      ],
      "reason": "Needed for private or internal GitHub Packages metadata and package-version reads."
    },
    {
      "scope": "write:packages",
      "enables": [
        "github_packages.publish_guard"
      ],
      "reason": "Needed only for explicitly approved publishing workflows, never for audit-only checks."
    }
  ],
  "workflow_job_permissions_required_by_checks": [
    {
      "permission": "id-token: write",
      "enables": [
        "common.short_lived_identity_policy",
        "pypi.trusted_publishing_and_attestations",
        "npm.trusted_publishing_and_provenance",
        "nuget.trusted_publishing",
        "rubygems.trusted_publishing"
      ],
      "reason": "Workflow job permission needed when the selected registry supports OIDC or trusted publishing."
    },
    {
      "permission": "attestations: write",
      "enables": [
        "common.attestation_permissions",
        "github_release_assets.attestation_verification",
        "docker_oci.provenance_and_sbom"
      ],
      "reason": "Workflow job permission needed only for GitHub artifact attestation generation."
    },
    {
      "permission": "artifact-metadata: write",
      "enables": [
        "common.linked_artifact_metadata"
      ],
      "reason": "Needed only when the workflow intentionally records linked artifact metadata."
    }
  ],
  "source_docs_ref": "../source-docs.json",
  "source_doc_scopes": [
    "artifact"
  ],
  "scope_policy": {
    "applies_when_any": [
      "detected_external_artifact_count > 0",
      "current_change_affects_artifact == true",
      "final_answer_makes_artifact_claim == true"
    ],
    "no_artifact_claim_requires": [
      "common.artifact_scope_trigger",
      "common.real_deliverable_classification",
      "common.no_artifact_consistency"
    ]
  },
  "remediation_policy": {
    "default_mode": "report_only",
    "publish_or_registry_mutation": "never_apply_from_audit_only_flow",
    "token_or_secret_changes": "manual_approval_required",
    "destructive_or_irreversible": "always_report_only",
    "auto_apply_checks": [],
    "manual_or_workflow_required_checks": [
      "common.publish_guard",
      "common.live_registry_verification",
      "common.short_lived_identity_policy",
      "common.local_build_package_consume",
      "pypi.*",
      "npm.*",
      "docker_oci.*",
      "maven.*",
      "nuget.*",
      "crates.*",
      "rubygems.*",
      "powershell_gallery.*",
      "github_packages.*",
      "github_release_assets.*",
      "docs_site.*"
    ]
  },
  "approved_drift": {
    "exclusions": [],
    "allowances": [
      {
        "id": "audit_only_may_skip_publish_steps",
        "when": "audit_only == true",
        "allowed_checks": [
          "common.publish_guard",
          "common.live_registry_verification"
        ],
        "requires_report": true
      },
      {
        "id": "no_external_artifact_is_valid_when_consistent",
        "when": "detected_external_artifact_count == 0 && no_artifact_docs_consistent == true",
        "allowed_checks": [
          "common.identity_contract",
          "common.local_build_package_consume",
          "common.live_registry_verification"
        ],
        "requires_report": false
      },
      {
        "id": "registry_without_trusted_publishing_support_may_use_scoped_token",
        "when": "selected_registry_supports_short_lived_identity == false && token_fallback_scope_is_minimal == true",
        "allowed_checks": [
          "common.short_lived_identity_policy"
        ],
        "requires_report": true
      },
      {
        "id": "private_or_internal_artifact_may_have_unreachable_public_endpoint",
        "when": "artifact_visibility in ['private','internal'] && token_scope_missing_for_registry_read == true",
        "allowed_checks": [
          "common.live_registry_verification",
          "github_packages.live_package_metadata"
        ],
        "requires_report": true
      }
    ]
  },
  "artifact_type_system": {
    "categories": [
      {
        "id": "container_images",
        "artifact_types": [
          "docker_oci_image",
          "github_container_registry_image",
          "generic_oci_registry_image"
        ]
      },
      {
        "id": "language_packages",
        "artifact_types": [
          "pypi_python_package",
          "npm_package",
          "maven_package",
          "gradle_maven_package",
          "nuget_package",
          "crates_package",
          "rubygems_package",
          "powershell_gallery_module"
        ]
      },
      {
        "id": "github_packages",
        "artifact_types": [
          "github_packages_container",
          "github_packages_npm",
          "github_packages_maven",
          "github_packages_gradle",
          "github_packages_nuget",
          "github_packages_rubygems"
        ]
      },
      {
        "id": "release_assets",
        "artifact_types": [
          "github_release_binary",
          "generic_binary_archive",
          "installer_or_cli_binary"
        ]
      },
      {
        "id": "documentation_and_sites",
        "artifact_types": [
          "github_pages_site",
          "static_docs_site"
        ]
      },
      {
        "id": "iac_and_modules",
        "artifact_types": [
          "terraform_module",
          "helm_chart"
        ]
      },
      {
        "id": "none",
        "artifact_types": [
          "no_artifact"
        ]
      }
    ],
    "detectors": [
      {
        "artifact_type": "docker_oci_image",
        "confidence": "high",
        "when_any_path_matches": [
          "Dockerfile",
          "**/Dockerfile"
        ]
      },
      {
        "artifact_type": "github_container_registry_image",
        "confidence": "high",
        "when_workflow_contains_any": [
          "ghcr.io/",
          "docker/build-push-action",
          "docker/login-action"
        ]
      },
      {
        "artifact_type": "generic_oci_registry_image",
        "confidence": "medium",
        "when_workflow_contains_any": [
          "docker push",
          "oras push",
          "podman push",
          "registry-1.docker.io",
          "quay.io",
          "public.ecr.aws"
        ]
      },
      {
        "artifact_type": "pypi_python_package",
        "confidence": "high",
        "when_any_path_matches": [
          "pyproject.toml",
          "setup.cfg",
          "setup.py"
        ],
        "and_when_any_file_contains_any": [
          "[project]",
          "[build-system]",
          "pypa/gh-action-pypi-publish",
          "twine upload"
        ]
      },
      {
        "artifact_type": "npm_package",
        "confidence": "high",
        "when_any_path_matches": [
          "package.json"
        ],
        "and_when_any_file_contains_any": [
          "\"name\"",
          "\"version\"",
          "npm publish",
          "registry.npmjs.org"
        ]
      },
      {
        "artifact_type": "maven_package",
        "confidence": "high",
        "when_any_path_matches": [
          "pom.xml"
        ]
      },
      {
        "artifact_type": "gradle_maven_package",
        "confidence": "high",
        "when_any_path_matches": [
          "build.gradle",
          "build.gradle.kts",
          "settings.gradle",
          "settings.gradle.kts"
        ],
        "and_when_any_file_contains_any": [
          "maven-publish",
          "publishing {",
          "central.sonatype.com",
          "mavenCentral"
        ]
      },
      {
        "artifact_type": "nuget_package",
        "confidence": "high",
        "when_any_path_matches": [
          "*.csproj",
          "*.fsproj",
          "*.vbproj",
          "*.nuspec"
        ],
        "and_when_any_file_contains_any": [
          "PackageId",
          "GeneratePackageOnBuild",
          "dotnet pack",
          "dotnet nuget push",
          "nuget push"
        ]
      },
      {
        "artifact_type": "crates_package",
        "confidence": "high",
        "when_any_path_matches": [
          "Cargo.toml"
        ],
        "and_when_any_file_contains_any": [
          "[package]",
          "cargo publish",
          "crates.io"
        ]
      },
      {
        "artifact_type": "rubygems_package",
        "confidence": "high",
        "when_any_path_matches": [
          "*.gemspec"
        ],
        "and_when_any_file_contains_any": [
          "Gem::Specification",
          "gem push",
          "rubygems.org"
        ]
      },
      {
        "artifact_type": "powershell_gallery_module",
        "confidence": "high",
        "when_any_path_matches": [
          "*.psd1"
        ],
        "and_when_any_file_contains_any": [
          "RootModule",
          "ModuleVersion",
          "Publish-Module",
          "PowerShell Gallery"
        ]
      },
      {
        "artifact_type": "github_release_binary",
        "confidence": "high",
        "when_release_assets_count_gt": 0
      },
      {
        "artifact_type": "generic_binary_archive",
        "confidence": "medium",
        "when_any_path_matches": [
          "dist/**",
          "build/**",
          "artifacts/**"
        ],
        "and_when_any_file_contains_any": [
          "gh release upload",
          "upload-release-asset",
          "softprops/action-gh-release"
        ]
      },
      {
        "artifact_type": "installer_or_cli_binary",
        "confidence": "medium",
        "when_any_file_contains_any": [
          "goreleaser",
          "cargo install",
          "winget",
          "scoop",
          "brew tap",
          "msix",
          "msi",
          "setup.exe"
        ]
      },
      {
        "artifact_type": "github_pages_site",
        "confidence": "high",
        "when": "repo.has_pages == true"
      },
      {
        "artifact_type": "static_docs_site",
        "confidence": "medium",
        "when_any_path_matches": [
          "docs/**",
          "site/**",
          "public/**",
          "mkdocs.yml",
          "docusaurus.config.*",
          "next.config.*"
        ],
        "and_when_any_file_contains_any": [
          "pages",
          "deploy-pages",
          "mkdocs gh-deploy",
          "github-pages"
        ]
      },
      {
        "artifact_type": "terraform_module",
        "confidence": "medium",
        "when_any_path_matches": [
          "*.tf",
          "modules/**"
        ],
        "and_when_any_file_contains_any": [
          "terraform registry",
          "registry.terraform.io"
        ]
      },
      {
        "artifact_type": "helm_chart",
        "confidence": "high",
        "when_any_path_matches": [
          "Chart.yaml",
          "charts/**/Chart.yaml"
        ]
      },
      {
        "artifact_type": "no_artifact",
        "confidence": "high",
        "when": "no_artifact_detectors_match && release_assets_count == 0 && no_publish_workflow_detected"
      }
    ],
    "resolution_rules": [
      {
        "id": "multi_artifact_repos_are_allowed",
        "rule": "A repo may publish several artifact types; every detected external artifact gets its own identity record and applicable checks."
      },
      {
        "id": "registry_signal_beats_manifest_presence_for_publish_claim",
        "rule": "A manifest can indicate a buildable package, but a publish workflow, release asset, registry package, or explicit contract is needed before claiming it is externally published."
      },
      {
        "id": "github_packages_is_registry_not_artifact_shape",
        "rule": "GitHub Packages may host containers, npm, Maven, NuGet, or RubyGems packages; run both the underlying artifact-type checks and GitHub Packages visibility/access checks."
      },
      {
        "id": "no_artifact_is_a_state",
        "rule": "No-artifact is valid only when manifests, workflows, releases, docs, and package registry signals are consistent with that posture."
      }
    ]
  },
  "fetch_bundles": {
    "local_artifact_bundle": {
      "description": "Single local scan for manifests, workflows, release config, changelog, build files, packaging outputs, and docs publish signals.",
      "sources": [
        "git_tree",
        "README*",
        "CHANGELOG*",
        "RELEASE*",
        ".github/workflows/*",
        "Dockerfile",
        "**/Dockerfile",
        ".dockerignore",
        "pyproject.toml",
        "setup.cfg",
        "setup.py",
        "package.json",
        "package-lock.json",
        "npm-shrinkwrap.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "pom.xml",
        "build.gradle",
        "build.gradle.kts",
        "*.csproj",
        "*.fsproj",
        "*.vbproj",
        "*.nuspec",
        "Cargo.toml",
        "Cargo.lock",
        "*.gemspec",
        "*.psd1",
        "Chart.yaml",
        "*.tf"
      ],
      "feeds_checks": [
        "common.real_deliverable_classification",
        "common.identity_contract",
        "common.version_source",
        "common.local_build_package_consume",
        "common.short_lived_identity_policy",
        "common.attestation_permissions",
        "docker_oci.*",
        "pypi.*",
        "npm.*",
        "maven.*",
        "nuget.*",
        "crates.*",
        "rubygems.*",
        "powershell_gallery.*",
        "github_release_assets.*",
        "docs_site.*"
      ]
    },
    "github_release_bundle": {
      "description": "GitHub release, tag, and release-asset metadata for release artifacts and version verification.",
      "endpoints": [
        "GET /repos/${owner}/${repo}/releases?per_page=100",
        "GET /repos/${owner}/${repo}/tags?per_page=100"
      ],
      "feeds_checks": [
        "common.version_source",
        "common.live_registry_verification",
        "github_release_assets.assets_and_tags"
      ]
    },
    "github_packages_bundle": {
      "description": "GitHub Packages metadata for supported package registries.",
      "endpoints": [
        "GET /orgs/${owner}/packages?package_type=container",
        "GET /orgs/${owner}/packages?package_type=npm",
        "GET /orgs/${owner}/packages?package_type=maven",
        "GET /orgs/${owner}/packages?package_type=nuget",
        "GET /orgs/${owner}/packages?package_type=rubygems",
        "GET /users/${owner}/packages?package_type=container",
        "GET /users/${owner}/packages?package_type=npm",
        "GET /users/${owner}/packages?package_type=maven",
        "GET /users/${owner}/packages?package_type=nuget",
        "GET /users/${owner}/packages?package_type=rubygems"
      ],
      "endpoint_selection": "Use /orgs when owner_type is org; use /users when owner_type is user; autodetect from repo.owner.type.",
      "feeds_checks": [
        "github_packages.live_package_metadata"
      ]
    },
    "registry_metadata_bundle": {
      "description": "Registry-specific live metadata. The checker calls only the endpoints for detected artifact types.",
      "endpoints_by_type": {
        "pypi_python_package": [
          "GET https://pypi.org/pypi/${package}/json",
          "GET https://pypi.org/simple/${package}/"
        ],
        "npm_package": [
          "GET https://registry.npmjs.org/${package}"
        ],
        "maven_package": [
          "GET https://search.maven.org/solrsearch/select?q=g:${groupId}+AND+a:${artifactId}"
        ],
        "nuget_package": [
          "GET https://api.nuget.org/v3-flatcontainer/${package}/index.json"
        ],
        "crates_package": [
          "GET https://crates.io/api/v1/crates/${crate}"
        ],
        "rubygems_package": [
          "GET https://rubygems.org/api/v1/gems/${gem}.json"
        ],
        "powershell_gallery_module": [
          "GET https://www.powershellgallery.com/api/v2/Packages?$filter=Id eq '${module}'"
        ],
        "docker_oci_image": [
          "registry_manifest_inspect:${image}:${tag_or_digest}",
          "GET https://hub.docker.com/v2/namespaces/${docker_namespace}/repositories/${docker_repository}/",
          "GET https://hub.docker.com/v2/namespaces/${docker_namespace}/repositories/${docker_repository}/tags?page_size=25&ordering=last_updated"
        ],
        "helm_chart": [
          "helm_repo_index:${chart_repository}"
        ]
      },
      "feeds_checks": [
        "common.live_registry_verification",
        "pypi.live_version_install_smoke",
        "npm.live_package_version_smoke",
        "maven.live_component_verification",
        "nuget.live_package_verification",
        "crates.live_crate_verification",
        "rubygems.live_gem_verification",
        "powershell_gallery.live_module_verification",
        "docker_oci.live_image_verification"
      ]
    },
    "post_publish_consumer_bundle": {
      "description": "Local smoke checks for the exact published artifact, not an editable checkout.",
      "commands_by_type": {
        "pypi_python_package": [
          "python -m pip install ${package}==${version}",
          "${post_publish_consumer_check}"
        ],
        "npm_package": [
          "npm view ${package}@${version} version",
          "${post_publish_consumer_check}"
        ],
        "maven_package": [
          "mvn dependency:get -Dartifact=${groupId}:${artifactId}:${version}",
          "${post_publish_consumer_check}"
        ],
        "nuget_package": [
          "dotnet add package ${package} --version ${version}",
          "${post_publish_consumer_check}"
        ],
        "crates_package": [
          "cargo install ${crate} --version ${version} --locked",
          "${post_publish_consumer_check}"
        ],
        "rubygems_package": [
          "gem install ${gem} -v ${version}",
          "${post_publish_consumer_check}"
        ],
        "powershell_gallery_module": [
          "Install-PSResource ${module} -Version ${version}",
          "${post_publish_consumer_check}"
        ],
        "docker_oci_image": [
          "docker pull ${image}@${digest_or_tag}",
          "${post_publish_consumer_check}"
        ],
        "github_release_binary": [
          "download_release_asset:${release}:${asset}",
          "${post_publish_consumer_check}"
        ],
        "github_pages_site": [
          "GET ${pages_url}",
          "${post_publish_consumer_check}"
        ]
      },
      "feeds_checks": [
        "common.local_build_package_consume",
        "common.live_registry_verification"
      ]
    }
  },
  "checks": [
    {
      "id": "common.artifact_scope_trigger",
      "source_lines": [
        "gh-artifact-contract.md:3-6"
      ],
      "category": "common",
      "kind": "classification",
      "comparison": "scope_policy",
      "applies_when": "always",
      "expected": {
        "run_contract_when_any_scope_policy_trigger_matches": true,
        "otherwise_result": "not_applicable"
      }
    },
    {
      "id": "common.real_deliverable_classification",
      "source_lines": [
        "gh-artifact-contract.md:3-6",
        "gh-artifact-contract.md:3-6"
      ],
      "category": "common",
      "kind": "tree_workflow_release_registry_scan",
      "comparison": "artifact_type_system",
      "applies_when": "common.artifact_scope_trigger",
      "expected": {
        "must_classify_all_detected_artifacts": true,
        "must_not_force_default_registry": true,
        "must_record_evidence_per_artifact": true
      }
    },
    {
      "id": "common.identity_contract",
      "source_lines": [
        "gh-artifact-contract.md:3-6"
      ],
      "category": "common",
      "kind": "contract_and_metadata",
      "comparison": "required_fields_present",
      "applies_when": "detected_external_artifact_count > 0",
      "expected": {
        "required_per_artifact_fields": [
          "artifact_type",
          "registry",
          "package_or_image_name",
          "version_source",
          "release_policy",
          "tag_style",
          "changelog_source",
          "post_publish_consumer_check"
        ],
        "registry_target_must_match_workflow_and_docs": true,
        "package_name_must_match_manifest_and_registry": true
      }
    },
    {
      "id": "common.audit_only_no_publish",
      "source_lines": [
        "gh-artifact-contract.md:3-6"
      ],
      "category": "common",
      "kind": "mode_guard",
      "comparison": "publish_mutation_absent",
      "applies_when": "audit_only == true",
      "expected": {
        "no_registry_publish": true,
        "no_release_creation": true,
        "no_tag_creation": true,
        "no_package_delete": true,
        "classify_artifact_state_only": true
      }
    },
    {
      "id": "common.local_build_package_consume",
      "source_lines": [
        "gh-artifact-contract.md:3-6",
        "gh-artifact-contract.md:3-6",
        "gh-artifact-contract.md:3-6",
        "gh-artifact-contract.md:3-6"
      ],
      "category": "common",
      "kind": "local_command_evidence",
      "comparison": "type_specific_smoke_policy",
      "applies_when": "current_change_affects_artifact == true || final_answer_makes_artifact_claim == true || merged_change_requires_release == true",
      "expected": {
        "build_or_package_command_succeeds": true,
        "artifact_can_be_installed_pulled_run_or_consumed": true,
        "published_artifact_smoke_uses_registry_artifact_not_editable_checkout": true
      }
    },
    {
      "id": "common.publish_guard",
      "source_lines": [
        "gh-artifact-contract.md:3-6"
      ],
      "category": "common",
      "kind": "policy_guard",
      "comparison": "release_required_before_publish",
