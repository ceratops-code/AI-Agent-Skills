{
  "contract_format_version": 1,
  "kind": "repo_code_contract",
  "name": "ceratops_code_repo_deterministic_contract",
  "captured_on": "2026-05-02",
  "source_files": [
    {
      "path": "$AI_AGENT_SKILLS_ROOT/contracts/source-docs.json",
      "lines": "source-doc registry"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/templates/sections/gh-repo-health-contract.md",
      "lines": "contract owner"
    }
  ],
  "parameters": {
    "owner": {
      "type": "string",
      "required": true
    },
    "repo": {
      "type": "string",
      "required": true
    },
    "default_branch": {
      "type": "string",
      "required": false,
      "default_from": "repo.default_branch"
    },
    "expected_codeowners_owners": {
      "type": "array",
      "required": false,
      "default": []
    },
    "expected_required_checks": {
      "type": "array",
      "required": false,
      "default": []
    },
    "artifact_publishers": {
      "type": "array",
      "required": false,
      "default": []
    },
    "local_repo_path": {
      "type": "string",
      "required": false
    },
    "expected_maintainer_bypass_actors": {
      "type": "array",
      "required": false,
      "default": []
    },
    "approved_drift_profile": {
      "type": "string",
      "required": false,
      "default": "default"
    }
  },
  "required_scopes": [
    "repo"
  ],
  "optional_scopes_for_full_screen_parity": [],
  "source_docs_ref": "../source-docs.json",
  "source_doc_scopes": [
    "repo_content"
  ],
  "approved_drift": {
    "exclusions": [],
    "allowances": [
      {
        "id": "forks_may_defer_enforcement_to_upstream",
        "when": "repo.fork == true",
        "check_ids": [
          "process.default_branch_enforcement_present",
          "process.branch_protection_or_ruleset_posture",
          "security.dependency_review_availability"
        ],
        "reason": "Forks can have unavailable or upstream-owned enforcement surfaces; classify rather than mutate."
      },
      {
        "id": "archived_repos_report_only",
        "when": "repo.archived == true",
        "check_ids": [
          "*"
        ],
        "reason": "Archived repositories are immutable health inventory, not repair targets."
      }
    ]
  },
  "remediation_policy": {
    "default": "report_only",
    "apply_flag": null,
    "auto_apply_check_ids": [],
    "manual_check_ids": [
      "actions.workflow_sha_pinning",
      "content.codeowners_valid",
      "content.local_secret_pattern_scan",
      "content.required_files_presence",
      "local.git_state",
      "security.dependabot_config_file",
      "stale_state.local_path_references",
      "type.language_signals",
      "type.path_signals"
    ],
    "destructive_or_irreversible": "always_report_only"
  },
  "type_system": {
    "dimensions": [
      {
        "id": "visibility",
        "values": [
          "public",
          "private",
          "internal"
        ],
        "detector": "repo.visibility"
      },
      {
        "id": "origin",
        "values": [
          "source",
          "fork",
          "template"
        ],
        "detectors": [
          {
            "value": "fork",
            "when": "repo.fork == true"
          },
          {
            "value": "template",
            "when": "repo.is_template == true"
          },
          {
            "value": "source",
            "when": "repo.fork == false && repo.is_template == false"
          }
        ]
      },
      {
        "id": "lifecycle",
        "values": [
          "active",
          "archived",
          "disabled"
        ],
        "detectors": [
          {
            "value": "archived",
            "when": "repo.archived == true"
          },
          {
            "value": "disabled",
            "when": "repo.disabled == true"
          },
          {
            "value": "active",
            "when": "repo.archived == false && repo.disabled == false"
          }
        ]
      },
      {
        "id": "project_surface",
        "values": [
          "software",
          "documentation_only",
          "iac",
          "automation",
          "website",
          "library_or_sdk",
          "service_or_app",
          "unknown"
        ],
        "detectors": [
          {
            "value": "software",
            "when_any_path_matches": [
              "src/**",
              "app/**",
              "lib/**",
              "pyproject.toml",
              "package.json",
              "go.mod",
              "Cargo.toml",
              "pom.xml",
              "*.csproj",
              "*.sln"
            ]
          },
          {
            "value": "library_or_sdk",
            "when_any_path_matches": [
              "pyproject.toml",
              "package.json",
              "go.mod",
              "Cargo.toml",
              "pom.xml",
              "*.csproj",
              "*.nuspec",
              "*.gemspec"
            ]
          },
          {
            "value": "iac",
            "when_any_path_matches": [
              "*.tf",
              "Chart.yaml",
              "charts/**/Chart.yaml",
              "k8s/**",
              "kubernetes/**",
              "manifests/**"
            ]
          },
          {
            "value": "automation",
            "when_any_path_matches": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml",
              "action.yml",
              "action.yaml",
              "scripts/**"
            ]
          },
          {
            "value": "website",
            "when_any_path_matches": [
              "docs/**",
              "public/**",
              "site/**",
              "mkdocs.yml",
              "docusaurus.config.*",
              "next.config.*"
            ],
            "or_when": "repo.has_pages == true"
          },
          {
            "value": "service_or_app",
            "when_any_path_matches": [
              "Dockerfile",
              "**/Dockerfile",
              "Procfile",
              "docker-compose.yml",
              "compose.yml",
              "compose.yaml",
              "app/**"
            ]
          },
          {
            "value": "documentation_only",
            "when": "tree_has_readme_or_docs == true && no_software_artifact_iac_or_workflow_signals == true"
          }
        ]
      },
      {
        "id": "workflow_surface",
        "values": [
          "no_workflows",
          "has_workflows",
          "has_release_workflow",
          "has_attestation_workflow"
        ],
        "detectors": [
          {
            "value": "has_workflows",
            "when_any_path_matches": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml"
            ]
          },
          {
            "value": "has_release_workflow",
            "when_workflow_contains_any": [
              "gh release",
              "softprops/action-gh-release",
              "pypa/gh-action-pypi-publish",
              "npm publish",
              "docker/build-push-action",
              "docker/login-action",
              "crates.io",
              "rubygems",
              "nuget push",
              "mvn deploy"
            ]
          },
          {
            "value": "has_attestation_workflow",
            "when_workflow_contains_any": [
              "actions/attest",
              "attestations: write",
              "artifact-metadata: write"
            ]
          }
        ]
      },
      {
        "id": "artifact_surface",
        "values": [
          "no_artifact",
          "docker_oci_image",
          "pypi_python_package",
          "npm_package",
          "maven_package",
          "nuget_package",
          "crates_package",
          "rubygems_package",
          "powershell_gallery_module",
          "github_release_binary",
          "github_pages_site",
          "github_packages_other"
        ],
        "detectors": [
          {
            "value": "docker_oci_image",
            "confidence": "high",
            "when_any_path_matches": [
              "Dockerfile",
              "docker/Dockerfile",
              "**/Dockerfile"
            ]
          },
          {
            "value": "docker_oci_image",
            "confidence": "high",
            "when_any_topic_matches": [
              "docker",
              "oci",
              "container",
              "ghcr"
            ]
          },
          {
            "value": "pypi_python_package",
            "confidence": "high",
            "when_any_path_matches": [
              "pyproject.toml",
              "setup.cfg",
              "setup.py"
            ],
            "and_when_file_contains_any": {
              "pyproject.toml": [
                "[project]",
                "[tool.poetry]",
                "[build-system]"
              ]
            }
          },
          {
            "value": "npm_package",
            "confidence": "high",
            "when_any_path_matches": [
              "package.json"
            ]
          },
          {
            "value": "maven_package",
            "confidence": "high",
            "when_any_path_matches": [
              "pom.xml"
            ]
          },
          {
            "value": "nuget_package",
            "confidence": "high",
            "when_any_path_matches": [
              "*.csproj",
              "*.nuspec"
            ]
          },
          {
            "value": "crates_package",
            "confidence": "high",
            "when_any_path_matches": [
              "Cargo.toml"
            ]
          },
          {
            "value": "rubygems_package",
            "confidence": "high",
            "when_any_path_matches": [
              "*.gemspec",
              "Gemfile"
            ]
          },
          {
            "value": "powershell_gallery_module",
            "confidence": "high",
            "when_any_path_matches": [
              "*.psd1"
            ]
          },
          {
            "value": "github_release_binary",
            "confidence": "medium",
            "when_release_assets_count_gt": 0
          },
          {
            "value": "github_pages_site",
            "confidence": "high",
            "when": "repo.has_pages == true"
          }
        ]
      },
      {
        "id": "language_or_iac",
        "values": [
          "python",
          "javascript_or_typescript",
          "go",
          "rust",
          "dotnet",
          "java",
          "terraform",
          "kubernetes",
          "helm",
          "github_actions"
        ],
        "detectors": [
          {
            "value": "python",
            "when_any_path_matches": [
              "pyproject.toml",
              "requirements*.txt",
              "*.py"
            ]
          },
          {
            "value": "javascript_or_typescript",
            "when_any_path_matches": [
              "package.json",
              "*.js",
              "*.ts",
              "*.tsx"
            ]
          },
          {
            "value": "go",
            "when_any_path_matches": [
              "go.mod"
            ]
          },
          {
            "value": "rust",
            "when_any_path_matches": [
              "Cargo.toml"
            ]
          },
          {
            "value": "dotnet",
            "when_any_path_matches": [
              "*.csproj",
              "*.sln"
            ]
          },
          {
            "value": "java",
            "when_any_path_matches": [
              "pom.xml",
              "build.gradle",
              "build.gradle.kts"
            ]
          },
          {
            "value": "terraform",
            "when_any_path_matches": [
              "*.tf"
            ]
          },
          {
            "value": "kubernetes",
            "when_any_file_contains_any": [
              "apiVersion:",
              "kind: Deployment",
              "kind: Service",
              "kind: Ingress"
            ]
          },
          {
            "value": "helm",
            "when_any_path_matches": [
              "Chart.yaml",
              "charts/**/Chart.yaml"
            ]
          },
          {
            "value": "github_actions",
            "when_any_path_matches": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml"
            ]
          }
        ]
      }
    ],
    "type_resolution_rules": [
      {
        "id": "topics_are_secondary",
        "rule": "Repository topics can add types, but path, manifest, workflow, release, and API signals are stronger than topics alone."
      },
      {
        "id": "multi_type_repos_are_allowed",
        "rule": "A repo may have multiple artifact, language, and IaC types; all matching conditional checks apply unless approved drift excludes them."
      },
      {
        "id": "archived_repos_are_inventory",
        "rule": "Archived repos are classified, but mutating repair checks become report-only."
      }
    ]
  },
  "fetch_bundles": [
    {
      "id": "repo_content_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/git/trees/${default_branch}?recursive=1",
          "covers_checks": [
            "type.path_signals",
            "content.required_files_presence",
            "security.dependabot_config_file",
            "stale_state.local_path_references"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/languages",
          "covers_checks": [
            "type.language_signals"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/codeowners/errors",
          "covers_checks": [
            "content.codeowners_valid"
          ]
        }
      ]
    },
    {
      "id": "local_repo_scan_bundle",
      "sources": [
        "${local_repo_path}"
      ],
      "covers_checks": [
        "type.path_signals",
        "actions.workflow_sha_pinning",
        "security.dependabot_config_file",
        "content.required_files_presence",
        "local.git_state",
        "content.local_secret_pattern_scan",
        "stale_state.local_path_references"
      ],
      "applies_when": "local_repo_path is provided"
    }
  ],
  "checks": [
    {
      "id": "type.path_signals",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "classification",
      "comparison": "derive_types_from_tree",
      "applies_when": "always",
      "expected": {
        "must_record_matching_type_rules": true
      }
    },
    {
      "id": "type.language_signals",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards"
      ],
      "kind": "classification",
      "comparison": "derive_types_from_languages",
      "applies_when": "always",
      "expected": {
        "must_not_override_manifest_signals": true
      }
    },
    {
      "id": "actions.workflow_sha_pinning",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "tree_scan",
      "comparison": "workflow_uses_policy",
      "applies_when": "type.workflow_surface has has_workflows",
      "expected": {
        "local_actions_allowed_unpinned": true,
        "external_actions_ref_pattern": "^[0-9a-f]{40}$",
        "same_line_release_comment_required": true,
        "reusable_workflow_tag_refs": "classify_deliberately"
      }
    },
    {
      "id": "security.dependabot_config_file",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "tree_scan",
      "comparison": "dependabot_manifest_policy",
      "applies_when": "repo.archived == false && repo.fork == false && package_manifests_present == true",
      "expected": {
        "dependabot_yml_present": true,
        "updates_entries_cover_detected_package_ecosystems": true,
        "schedule_interval_present_for_each_updates_entry": true,
        "open_pull_requests_limit_classified": true,
        "groups_classified_when_used": true,
        "private_registries_classified_when_used": true,
        "labels_referenced_by_dependabot_exist": true
      }
    },
    {
      "id": "content.required_files_presence",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api_and_tree",
      "comparison": "file_presence_policy",
      "applies_when": "repo.archived == false",
      "expected": {
        "all_repos": [
          "README.md"
        ],
        "public_source_repos": [
          "LICENSE",
          "SECURITY.md",
          "CONTRIBUTING.md",
          "CODE_OF_CONDUCT.md",
          ".github/CODEOWNERS"
        ],
        "when_has_issues": [
          ".github/ISSUE_TEMPLATE/**",
          ".github/ISSUE_TEMPLATE.md"
        ],
        "when_has_pull_requests": [
          ".github/PULL_REQUEST_TEMPLATE.md",
          ".github/pull_request_template.md",
          ".github/PULL_REQUEST_TEMPLATE/**"
        ],
        "when_artifact_surface_present": [
          "CHANGELOG.md",
          "docs/**",
          "examples/**"
        ],
        "contextual_expectations": true
      }
    },
    {
      "id": "content.codeowners_valid",
      "source_lines": [
        "source-docs.json:repo-and-artifact-standards",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/codeowners/errors",
      "comparison": "empty_errors",
      "applies_when": "tree contains .github/CODEOWNERS || tree contains CODEOWNERS || tree contains docs/CODEOWNERS",
      "expected": {
        "errors": []
      }
    },
    {
      "id": "local.git_state",
      "source_lines": [
        "ceratops-gh-repo-health-audit/SKILL.md:125",
        "ceratops-gh-repo-create-and-publish/SKILL.md:171"
      ],
      "kind": "local_git",
      "comparison": "git_state_policy",
      "applies_when": "local_repo_path is provided",
      "expected": {
        "worktree_clean": true,
        "current_branch": "${default_branch}",
        "tracks_remote_default_branch": true,
        "unmerged_local_branches_classified": true
      }
    },
    {
      "id": "stale_state.local_path_references",
      "source_lines": [
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "tree_scan",
      "comparison": "regex_absence_or_approved",
      "applies_when": "repo.archived == false",
      "expected": {
        "forbidden_patterns": [
          "[A-Za-z]:\\\\",
          "/Users/",
          "/home/[^/]+/"
        ],
        "allow_when": "external_runtime_requires_absolute_path_and_documented"
      }
    },
    {
      "id": "content.local_secret_pattern_scan",
      "source_lines": [
        "scripts/validation/validate-skills-consistency.py:76-84",
        "gh-repo-health-contract.md:3-8"
      ],
      "kind": "tree_scan",
      "comparison": "regex_absence_or_approved",
      "applies_when": "local_repo_path is provided && repo.archived == false",
      "expected": {
        "forbidden_patterns": [
          "AKIA[0-9A-Z]{16}",
          "gh[pousr]_[A-Za-z0-9_]{20,}",
          "github_pat_[A-Za-z0-9_]{20,}",
          "sk-[A-Za-z0-9_-]{20,}",
          "xox[baprs]-[A-Za-z0-9-]{10,}",
          "BEGIN (?:RSA |OPENSSH |EC |DSA )?PRIVATE KEY"
        ],
        "allow_when": "known_test_fixture_or_placeholder_and_documented"
      }
    }
  ],
  "non_deterministic_review_file": "code-repo-nondeterministic-contract.md"
}
